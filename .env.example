# health-platform — infrastruktur bersama PPKP DKI
# Salin: Copy-Item .env.example .env

COMPOSE_PROJECT_NAME=health-platform

# ── PostgreSQL (superuser — hanya init/DBA) ─────────────────────────────────
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres_local_secret
POSTGRES_PUBLISH_PORT=5432

# Produksi VM (docker-compose.prod.yml): POSTGRES_PUBLISH_PORT=5435 — lihat docs/deployment/PORTS.md

# Password per aplikasi — lihat docs/deployment/DATABASE-NAMING.md
# dashboard-skrining: sikerja / sikerja_ppkp
DASHBOARD_DB_PASSWORD=dashboard_local_secret
# mcu-monitor: mcu_monitor / mcu_monitor
MCU_DB_PASSWORD=Ppkp-Dev-2026!

# ── pgAdmin (satu UI, banyak database & server) ─────────────────────────────
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@local.test
PGADMIN_PASSWORD=Admin-Lokal123!
PGADMIN_SERVER_GROUP=Development
PGADMIN_SERVER_NAME=PPKP PostgreSQL (lokal)

# ── Redis shared (prefix per app di .env masing-masing service) ─────────────
REDIS_PUBLISH_PORT=6379

# Produksi VM: REDIS_PUBLISH_PORT=6380

# ── MinIO (backup object / arsip) ───────────────────────────────────────────
MINIO_ROOT_USER=ppkp_minio
MINIO_ROOT_PASSWORD=minio_local_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Produksi VM: MINIO_API_PORT=9100, MINIO_CONSOLE_PORT=9200
# Bucket arsip backup (buat di MinIO Console atau otomatis via skrip upload)
MINIO_BACKUP_BUCKET=minio.sikerja
MINIO_BACKUP_PREFIX=pg-backups

# ── Monitoring (profile: monitoring) ────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=Grafana-Lokal123!
LOKI_PORT=3100
# Produksi VM: GRAFANA_PORT=3200

# ── Reverse proxy (opsional) ────────────────────────────────────────────────
PROXY_HTTP_PORT=8080
