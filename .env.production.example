# health-platform — produksi VM (Linux)
# Salin: cp .env.production.example .env

COMPOSE_PROJECT_NAME=health-platform

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_SUPERUSER=ppkp-dki
POSTGRES_SUPERUSER_PASSWORD=GANTI_SUPERUSER_PASSWORD_KUAT
# Host VM (pg_dump / DBA) — aplikasi Docker tetap PGSQL_PORT=5432 internal
POSTGRES_PUBLISH_PORT=5435

# Harus sama dengan PGSQL_PASSWORD di masing-masing aplikasi
DASHBOARD_DB_PASSWORD=GANTI_DASHBOARD_DB_PASSWORD
MCU_DB_PASSWORD=GANTI_MCU_DB_PASSWORD

# ── pgAdmin (akses via SSH tunnel ke 127.0.0.1:5050) ─────────────────────────
PGADMIN_PORT=5050
PGADMIN_EMAIL=dba@ppkp.jakarta.go.id
PGADMIN_PASSWORD=GANTI_PGADMIN_PASSWORD_KUAT
PGADMIN_SERVER_GROUP=Production
PGADMIN_SERVER_NAME="PPKP PostgreSQL (produksi)"

# ── Redis shared (opsional — dashboard bisa pakai ppkp-redis) ────────────────
REDIS_PUBLISH_PORT=6380

# ── MinIO (backup object / arsip dump) ─────────────────────────────────────
MINIO_ROOT_USER=ppkp_minio
MINIO_ROOT_PASSWORD=GANTI_MINIO_PASSWORD_KUAT
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9200
MINIO_BACKUP_BUCKET=minio.sikerja
MINIO_BACKUP_PREFIX=pg-backups

# ── Monitoring (profile: monitoring) — bind localhost ───────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3200
GRAFANA_PASSWORD=GANTI_GRAFANA_PASSWORD
LOKI_PORT=3100

# Backup pg_dump ke folder host (butuh client postgresql di VM)
BACKUP_DIR=./storage/backups
